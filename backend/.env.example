DEPLOYMENT_TARGET=docker
OBJECT_STORAGE_PROVIDER=s3
JOB_BACKEND=rq
DOCUMENT_PARSER=local

SECRET_KEY_ACCESS_API=replace-with-at-least-32-random-characters
GUEST_SIGNING_SECRET=replace-with-at-least-32-random-characters
QUOTA_HASH_SECRET=replace-with-at-least-32-random-characters
INTERNAL_JOB_SECRET=replace-with-at-least-32-random-characters
GOOGLE_CLIENT_ID=replace-with-google-client-id
DATABASE_URL=postgresql://app:app@localhost:5432/equitylens
REDIS_URL=redis://localhost:6379/0

S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=filings
S3_ACCESS_KEY_ID=replace-with-minio-app-user
S3_SECRET_ACCESS_KEY=replace-with-minio-app-password

OPENAI_API_KEY=replace-with-openai-key
OPENAI_ORGANIZATION=replace-with-openai-organization
SEC_USER_AGENT=EquityLens admin@example.com
MARKET_DATA_PROVIDER=yahoo
RESEARCH_MODEL=gpt-5-mini
SUPPLY_CHAIN_GRAPH_MODEL_OVERRIDE=
SUPPLY_CHAIN_GRAPH_MAX_NODES=40
SUPPLY_CHAIN_GRAPH_EVIDENCE_THRESHOLD=0.75
SUPPLY_CHAIN_GRAPH_EVIDENCE_TOKEN_BUDGET=100000
GRAPH_ARTIFACT_PREFIX=supply-chain
SUPPLY_CHAIN_WORKFLOW_TRIGGER_URL=
CHAT_GUEST_DAILY_LIMIT=2
CHAT_USER_DAILY_LIMIT=10
CHAT_GUEST_RETENTION_DAYS=7
CHAT_MAX_MESSAGE_CHARS=2000
CHAT_MAX_HISTORY_MESSAGES=8
CHAT_CHUNK_TARGET_TOKENS=700
CHAT_CHUNK_OVERLAP_TOKENS=100
CHAT_CHUNK_MIN_FINAL_TOKENS=120
CHAT_RETRIEVAL_CANDIDATES=20
CHAT_RETRIEVAL_MAX_CHUNKS=8
CHAT_RETRIEVAL_MAX_PER_SECTION=3
CHAT_RETRIEVAL_TOKEN_BUDGET=6000
CHAT_RRF_K=60
CHAT_WEB_MAX_QUERIES=3
CHAT_WEB_MAX_PAGES=8
CHAT_WEB_SEARCH_PROVIDER=openai
CHAT_EMBEDDING_MODEL=text-embedding-3-small
CHAT_EMBEDDING_DIMENSIONS=1536
CHAT_MODEL_OVERRIDE=
CHAT_PROMPT_VERSION=company-chat.2026-07-14
CHAT_ANSWER_SCHEMA_VERSION=company-chat.v1
CHAT_INDEX_SCHEMA_VERSION=filing-chunk.v1
CHAT_INDEX_WORKFLOW_TRIGGER_URL=
CHAT_WEB_ARTIFACT_PREFIX=chat-web
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=replace-with-admin-password
CORS_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000
ACCESS_TOKEN_EXPIRE_MINUTES=15
