API_DOMAIN=api.example.com
API_PORT=18000
REVERSE_PROXY_MODE=caddy
FRONTEND_URL=https://equitylens-nu.vercel.app
CORS_ORIGINS=https://equitylens-nu.vercel.app

DEPLOYMENT_TARGET=vps
JOB_BACKEND=rq
REDIS_URL=redis://redis:6379/0
DOCUMENT_PARSER=managed
OBJECT_STORAGE_PROVIDER=vercel_blob
BLOB_READ_WRITE_TOKEN=replace-with-vercel-blob-token

POSTGRES_DB=equitylens
POSTGRES_USER=equitylens
POSTGRES_PASSWORD=replace-with-64-character-database-password
DATABASE_URL=postgresql://equitylens:replace-with-64-character-database-password@postgres:5432/equitylens
SECRET_KEY_ACCESS_API=replace-with-64-character-secret
GUEST_SIGNING_SECRET=replace-with-64-character-secret
QUOTA_HASH_SECRET=replace-with-64-character-secret
INTERNAL_JOB_SECRET=replace-with-64-character-secret

GOOGLE_CLIENT_ID=replace-with-google-client-id
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=replace-with-strong-password

OPENAI_API_KEY=replace-with-openai-key
OPENAI_ORGANIZATION=
OPENAI_BASE_URL=
LLM_API_KEY=replace-with-deepseek-key
LLM_BASE_URL=https://api.deepseek.com
LLM_STRUCTURED_OUTPUT_METHOD=json_mode
TAVILY_API_KEY=

SEC_USER_AGENT=EquityLens admin@example.com
MARKET_DATA_PROVIDER=yahoo
RESEARCH_MODEL=deepseek-v4-pro
SUPPLY_CHAIN_GRAPH_MODEL_OVERRIDE=deepseek-v4-pro
CHAT_MODEL_OVERRIDE=deepseek-v4-pro
CHAT_WEB_SEARCH_PROVIDER=tavily
CHAT_TAVILY_SEARCH_DEPTH=basic
CHAT_TAVILY_MAX_RESULTS=5
CHAT_EMBEDDING_MODEL=text-embedding-3-small
CHAT_EMBEDDING_DIMENSIONS=1536

SUPPLY_CHAIN_GRAPH_SCHEMA_VERSION=supply-chain-graph.v1
SUPPLY_CHAIN_GRAPH_PROMPT_VERSION=supply-chain-graph.2026-07-16-source-coverage-v3
SUPPLY_CHAIN_GRAPH_MIN_NODES=12
SUPPLY_CHAIN_GRAPH_MAX_NODES=40
SUPPLY_CHAIN_GRAPH_EVIDENCE_THRESHOLD=0.75
SUPPLY_CHAIN_GRAPH_SOURCE_LIMIT=24
SUPPLY_CHAIN_GRAPH_SOURCE_BYTES=64000000
SUPPLY_CHAIN_GRAPH_EVIDENCE_TOKEN_BUDGET=100000
SUPPLY_CHAIN_GRAPH_STAGE_TIMEOUT_SECONDS=180
SUPPLY_CHAIN_GRAPH_MAX_OUTPUT_TOKENS=16000
GRAPH_ARTIFACT_PREFIX=supply-chain
